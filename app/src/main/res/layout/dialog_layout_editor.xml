<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?attr/keyboardBg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTabLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Layout"
                android:textAllCaps="false"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center" />

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btnTabSideButtons"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Side buttons"
                android:textAllCaps="false"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnTabNumeric"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Numeric"
                android:textAllCaps="false"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center" />

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btnEditHorizontalCenter"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Horizontal"
                android:textAllCaps="false"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:id="@+id/pageLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvLayoutTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Set Layout"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />fun showPage(page: Int) {


            <FrameLayout
                android:id="@+id/layoutEditorContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/pageSideButtons"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvSideButtonsTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Side buttons"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <FrameLayout
                android:id="@+id/sideButtonsEditorContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/pageNumeric"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvNumericTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Numeric layout"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="12dp" />

            <FrameLayout
                android:id="@+id/numericEditorContainer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>

    </FrameLayout>

    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <Button
            android:id="@+id/btnSwapSelected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Zamijeni označene"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btnSaveEditor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Spremi"
            android:textAllCaps="false" />
    </LinearLayout>

</LinearLayout>