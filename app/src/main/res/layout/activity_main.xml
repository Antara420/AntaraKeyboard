<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/mainScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/keyboardBg">

    <LinearLayout
        android:id="@+id/mainRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- NASLOV -->
        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Antara Keyboard"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Enable + Choose -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnEnableKeyboard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enable"
                app:textAllCaps="false" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnChooseKeyboard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Choose"
                app:textAllCaps="false" />
        </LinearLayout>

        <!-- SET LAYOUT - full width -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSetLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Set Layout"
            app:textAllCaps="false" />

        <!-- Key shape -->
        <TextView
            android:id="@+id/tvKeyShape"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Key shape"
            android:textSize="18sp" />

        <RadioGroup
            android:id="@+id/shapeGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/hexBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hexagon" />

            <RadioButton
                android:id="@+id/triBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Triangle" />

            <RadioButton
                android:id="@+id/circleBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Circle" />

            <RadioButton
                android:id="@+id/cubeBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cube" />
        </RadioGroup>

        <com.example.antarakeyboard.ui.ShapePreviewView
            android:id="@+id/preview"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_marginTop="12dp" />

        <!-- Bind + Reset -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/bindLPButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bind LongPress"
                app:textAllCaps="false" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/resetLayoutButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reset Layout"
                app:textAllCaps="false" />
        </LinearLayout>

        <!-- Space + Enter color -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSpaceColor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Space color"
                app:textAllCaps="false" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnEnterColor"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enter color"
                app:textAllCaps="false" />
        </LinearLayout>

        <!-- Theme toggle -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnThemeToggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Switch theme"
            app:textAllCaps="false" />

    </LinearLayout>
</ScrollView>